        <mxCell id="jCA5kaOpUgITiMNAFa9Y-9" value="&lt;p style=&quot;line-height: 100%;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Backend tarafında&amp;nbsp;&lt;b style=&quot;&quot;&gt;Authentication controller&lt;/b&gt; içinde var olan metotolar&amp;nbsp; FrontEnd tarafında&amp;nbsp;&lt;b style=&quot;&quot;&gt;IAuthenticationApiClient &lt;/b&gt;interface&#39;inde Refit ile oluşturulmuştur.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="10" y="360" width="410" height="30" as="geometry" />
