        <mxCell id="jCA5kaOpUgITiMNAFa9Y-7" value="&lt;font style=&quot;font-size: 6px;&quot;&gt;Front-End tarafından Back-End tarafında HttpClient (Refit) ile erişim sağlanmaktadır.&amp;nbsp;&lt;br&gt;&lt;br&gt;Entegrasyon için yapılan işlemler:&lt;br&gt;-Her controller için FE tarafında ApiClient oluşturmak (Refit)&lt;br&gt;-FE controller yada cshtml dosyları içerisinde&amp;nbsp; database yada business logic işlemlerini ApiClient&#39;lar içinde yazılan metotları çağırarak yapıp, dönen response ile işlem yapılacak ise dönen modeli gerekli alanlara set edilmelidir.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="222" y="30" width="416" height="80" as="geometry" />
        </mxCell>
        <mxCell id="jCA5kaOpUgITiMNAFa9Y-8" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="9.96" y="400" width="415" height="100" as="geometry" />
