        <mxCell id="jCA5kaOpUgITiMNAFa9Y-12" value="Front-End projesinde var olan HhvnController içerisindeki Login metodu kodları &lt;b&gt;İLK HALİ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
