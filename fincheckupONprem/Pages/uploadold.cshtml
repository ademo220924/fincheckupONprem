@page

@using System.Threading
@using fincheckup.ApiClients.Models
@using fincheckup.ApiClients.Models.Requests.Upload
@using fincheckup.ApiClients.Models.Requests.Finance.Upload
@using fincheckup.ApiClients.Services
@using fincheckup.ApiClients.Services.Finance
@model IndexModel
@{
    ViewData["Title"] = "Giriş Ekranı";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}


@functions {
    public class IndexModel(IUploadClient apiClient, IUploadMainClient uploadMainClient) : PageModel
    {
        private readonly IUploadClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        private readonly IUploadMainClient _uploadMainClient = uploadMainClient ?? throw new ArgumentNullException(nameof(uploadMainClient));
        
        public UploadRequest InitialModel;
        

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new UploadOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }


        public async Task<JsonResult> OnGetSalerMainChk(DataSourceLoadOptions options, int monthid)
        {
            try
            {
                var response = await _apiClient.GetSalerMainChkAsync(new UploadOnGetSalerMainChkRequest()
                {
                    Options = options, monthid = monthid
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Result);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var Uploadold OnGetSalerMainChk");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        public async Task<JsonResult> OnGetSalerMainZeta(DataSourceLoadOptions options, int monthid)
        {
            try
            {
                var response = await _apiClient.GetSalerMainZetaAsync(new UploadOnGetSalerMainZetaRequest()
                {
                    Options = options, monthid = monthid
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data!.Result);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var Uploadold OnGetSalerMainZeta");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        public async Task<JsonResult> OnGetSalerDate(DataSourceLoadOptions options)
        {
            try
            {
                var response = await _apiClient.GetSalerDateAsync(new UploadOnGetSalerDateRequest()
                {
                    Options = options
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data!.Result);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var Uploadold OnGetSalerDate");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }

        }
        public async Task<JsonResult> OnGetSalerYear(DataSourceLoadOptions options)
        {
            try
            {
                var response = await _apiClient.GetSalerYearAsync(new UploadOnGetSalerYearRequest()
                {
                    Options = options
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data!.Result);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var Uploadold OnGetSalerYear");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }

        }
        public async Task<JsonResult> OnGetSalerComp(DataSourceLoadOptions options)
        {

            try
            {
                var response = await _uploadMainClient.GetSalerCompAsync(new FinanceUploadMainOnGetSalerCompRequest()
                {
                    options = options
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data?.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var Uploadold OnGetSalerComp");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }

        }

        public async Task<JsonResult> OnGetGraphComp(int ncompid)
        {
            try
            {
                var response = await _apiClient.GetGraphCompAsync(new UploadOnGetGraphCompRequest()
                {
                    ncompid = ncompid
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data!.Result);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var Uploadold OnGetGraphComp");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        
        public async Task<JsonResult> OnGetGraphYear(int nyear)
        {
            try
            {
                var response = await _apiClient.GetGraphYearAsync(new UploadOnGetGraphYearRequest()
                {
                    nyear = nyear
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data!.Result);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var Uploadold OnGetGraphYear");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

    }
