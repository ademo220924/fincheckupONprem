        function exporting(e) {
            e.component.beginUpdate();
            e.component.columnOption('DocumentDate', 'visible', true);
            e.component.columnOption('DetailComment', 'visible', true);
            e.component.columnOption('EnteredBy', 'visible', true);
            e.component.columnOption('DocumentTypeDescription', 'visible', true);
            e.component.columnOption('PaymentMethod', 'visible', true);
            e.component.columnOption('AccountMainDescription', 'visible', true);
            e.component.columnOption('AccountSubDescription', 'visible', true);
            e.component.columnOption('AccountSubID', 'visible', true);

            var workbook = new ExcelJS.Workbook();
            var worksheet = workbook.addWorksheet('Uyarı Alan Kayıtlar');

            worksheet.columns = [
                { width: 1 }, { width: 25 }, { width: 25 }, { width: 15 }, { width: 15 }, { width: 35 }, { width: 25 }, { width: 35 }, { width: 15 }, { width: 15 }, { width: 35 }, { width: 15 }, { width: 15 }, { width: 5 }, { width: 55 }
            ];
            var chkktxt = "";
            DevExpress.excelExporter.exportDataGrid({
                component: e.component,
                worksheet: worksheet,
                keepColumnWidths: false,
                topLeftCell: { row: 2, column: 2 },
                customizeCell: function (options) {
                    var gridCell = options.gridCell;
                    var excelCell = options.excelCell;
                    var chknum = 0;
                    if (gridCell.rowType === "data") {
                        if (gridCell.column.dataField === 'DocumentDate') {

                            chkktxt = $("#mainyear").val() + "_" + $("#mainmonth").val();
                        }
                        chknum = 0;



                    }
                    if (gridCell.rowType === "group") {
                        excelCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: "BEDFE6" } };
                    }
                }
            }).then(function () {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: "application/octet-stream" }), chkktxt + "_" + "kayitlar.xlsx");
                });
            });
            e.cancel = true;
        }

