<body class="theme-black  menu_sm">


@{
    var responseModel = await LayoutClient.LayoutFinanceMizanAsync(new LayoutFinanceMizanRequest(), CancellationToken.None);
    if (!responseModel.IsSuccess)
       Console.WriteLine("_LayoutFinanceMzn.cshtml sayfasında LayoutFinanceMizanAsync hata verdi");
     
    var usr =responseModel.Data?.HhvnUsers;
    var usrApp = responseModel.Data?.UserApp;
   
    if (!string.IsNullOrEmpty(usr?.qnbUserId))
    {
        Context.Response.Redirect("/admin/qnb/upload");
    }
}

