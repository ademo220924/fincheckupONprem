    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, User-scalable=0">
    <title>FinCheckup</title>
    <meta http-equiv="Content-Security-Policy" content="default-src *;
   img-src * 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' *;
   style-src  'self' 'unsafe-inline' *">
    <script src="~/js/customdash.js"></script>

    <link rel="apple-touch-icon" sizes="57x57" href="/apple-icon-57x57.png">
    <link rel="apple-touch-icon" sizes="60x60" href="/apple-icon-60x60.png">
    <link rel="apple-touch-icon" sizes="72x72" href="/apple-icon-72x72.png">
    <link rel="apple-touch-icon" sizes="76x76" href="/apple-icon-76x76.png">
    <link rel="apple-touch-icon" sizes="114x114" href="/apple-icon-114x114.png">
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-icon-120x120.png">
    <link rel="apple-touch-icon" sizes="144x144" href="/apple-icon-144x144.png">
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-icon-152x152.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/android-icon-192x192.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="msapplication-TileImage" content="/ms-icon-144x144.png">
    <meta name="theme-color" content="#ffffff">
    <link href="~/css/devextreme/bootstrap.css" rel="stylesheet" />
    <!-- Custom Css -->
    <!-- Custom Css -->
    <link rel="stylesheet" href="/assets/css/main.css">
    <link href="/assets/css/toastr.css" rel="stylesheet" />
    <link href="/css/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/css/color_skins.css">
    <link href="~/assets/css/sweetalert2.min.css" rel="stylesheet" />
    <link href="/css/devextreme/dx.common.css" rel="stylesheet" />
    <link href="/css/devextreme/dx.light.css" rel="stylesheet" />
    <script src="/js/devextreme/jquery.js"></script>
    <script src="~/js/devextreme/jszip.js"></script>
    <script src="/js/devextreme/dx.all.js"></script>

    <script src="/js/devextreme/aspnet/dx.aspnet.mvc.js"></script>
    <script src="/js/devextreme/aspnet/dx.aspnet.data.js"></script>
    <script src="~/js/devextreme/localization/dx.messages.tr.js"></script>
    @RenderSection("Styles", false)
    <script>
        DevExpress.localization.locale("tr");

    </script>
    <style>
        #slctCompany .dx-texteditor-input {
            text-align: right;
        }

        #slctYear .dx-texteditor-input {
            text-align: center;
        }

        #slctCompany .productname {
            text-align: right;
        }

        #maincrd {
            background-color: #2F96B4;
            background-position: 5px center;
            background-repeat: no-repeat;
            -moz-box-shadow: 0 0 12px #000;
            -webkit-box-shadow: 0 0 12px #000;
            box-shadow: 0 0 3px #000;
            color: #FFF;
            opacity: .9;
            font-size: medium;
            -ms-filter: progid:DXImageTransform.Microsoft.Alpha(Opacity=100);
            filter: alpha(opacity=100)
        }
    </style>
</head>
<body class="theme-black  menu_sm">





    <!-- Page Loader -->
    <div class="page-loader-wrapper">
        <div class="loader">
            <div class="m-t-30"><img src="/finnlogo.png" width="48" height="48" alt="FinCheckup"></div>
            <p>Lütfen Bekleyiniz...</p>
        </div>
    </div>
    <div class="overlay_menu">
        <button class="btn btn-primary btn-icon btn-icon-mini btn-round"><i class="zmdi zmdi-close"></i></button>
        <div class="container">
            <div class="row clearfix">
                <div class="card">
                    <div class="body">
                        <div class="input-group m-b-0">
                            <input type="text" class="form-control" placeholder="Search...">
                            <span class="input-group-addon">
                                <i class="zmdi zmdi-search"></i>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card links">
                    <div class="body">
                        <div class="row">
                            <div class="col-lg-3 col-md-6 col-sm-12">

                            </div>
                            <div class="col-lg-3 col-md-6 col-sm-12">

                            </div>
                            <div class="col-lg-3 col-md-6 col-sm-12">

                            </div>
                            <div class="col-lg-3 col-md-6 col-sm-12">

                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <div class="row clearfix">

            </div>
        </div>
    </div>
    <div class="overlay"></div><!-- Overlay For Sidebars -->
    <!-- Left Sidebar -->
    <aside id="minileftbar" class="minileftbar">
        <ul class="menu_list">
            <li>
                <a href="javascript:void(0);" class="bars"></a>
                <a class="navbar-brand" href="/admin/consult/index"><img src="/finnlogo.png" alt="FinCheckup"></a>
            </li>

            <li><a href="javascript:void(0);" class="menu-sm"><i class="zmdi zmdi-swap"></i></a></li>


            <li><a href="javascript:void(0);" class="fullscreen" data-provide="fullscreen"><i class="zmdi zmdi-fullscreen"></i></a></li>
            <li class="power">

                <a asp-page="/logout" asp-page-handler="logout" class="mega-menu"><i class="zmdi zmdi-power"></i></a>
            </li>
        </ul>
    </aside>
    <aside class="right_menu">

        <div id="rightsidebar" class="right-sidebar">
            <ul class="nav nav-tabs">
                <li class="nav-item"> </li>
            </ul>
            <div class="tab-content slim_scroll">
                <div class="tab-pane slideRight active" id="setting">

                    <div class="card">
                        <div class="header">
                            <h2><i class="fa fa-info-circle"></i> &nbsp;&nbsp;<strong>Info</strong> </h2>
                        </div>
                        <div class="body">
                            <div id="maincrd"></div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
        <div id="leftsidebar" class="sidebar">
            <div class="menu">
                <ul class="list">
                    <li>
                        <div class="user-info m-b-20">
                            <div class="image">
                                <a href="/admin/consult/index"><img src="/finnlogo.png" alt="User"></a>
                            </div>
                            <div class="detail">
                                <h6>FinCheckup</h6>
                                <p class="m-b-0">  Yönetim Paneli</p>

                            </div>
                        </div>
                    </li>

                    <li class="header">QNB Finansal Raporlama</li>
                    <li>
                        <a href="javascript:void(0);" class="menu-toggle"><i class="zmdi zmdi-pages"></i><span>QNB Finansal Raporlama</span> </a>
                        <ul class="ml-menu">
                            <li> <a href="/admin/consult/upreportqnb">QNB Finansal Raporlama</a></li>
                            <li> <a href="/admin/consult/reportmain">Temel Finansal Göstergeler</a></li>
                        </ul>



                    </li>
                    <li class="header">Nakit Risk Yönetimi</li>
                    <li>
                        <a href="javascript:void(0);" class="menu-toggle"><i class="zmdi zmdi-chart"></i><span style=" ">Detay Nakit Akışı</span> </a>
                        <ul class="ml-menu">

                            <li> <a href="/admin/consult/cashflow">Detay Nakit Akışı </a></li>

                        </ul>
                    </li>

                    <li class="header">Detay Raporlar</li>
                    <li>
                        <a href="javascript:void(0);" class="menu-toggle"><i class="zmdi zmdi-chart"></i><span style=" ">Detay Raporlar</span> </a>
                        <ul class="ml-menu">

                            <li> <a href="/admin/consult/dashbilanco">Bilanço</a></li>
                            <li> <a href="/admin/consult/dashrevenue">Gelir Tablosu</a></li>

                        </ul>
                    </li>
                    <li class="header">Aktarma & Arındırma </li>
                    <li>
                        <a href="javascript:void(0);" class="menu-toggle"><i class="zmdi zmdi-chart"></i><span>Aktarma & Arındırma Prosesi Başlatma</span> </a>
                        <ul class="ml-menu">

                            <li> <a href="/admin/consult/uppageaktarma">Aktarma-Arındırma Paneli</a></li>
                            <li> <a href="/admin/consult/aktarma/dashbilanco">Bilanço Trend</a></li>
                            <li> <a href="/admin/consult/aktarma/dashrevenue">Gelir Tablosu Trend</a></li>

                        </ul>
                    </li>
                    <li class="header">Journal Form </li>
                    <li>
                        <a href="javascript:void(0);" class="menu-toggle"><i class="zmdi zmdi-chart"></i><span>Journal Form Prosesi Başlatma</span> </a>
                        <ul class="ml-menu">

                            <li> <a href="/admin/consult/uppageaktarmajrnl">Journal Form  Paneli</a></li>
                            <li> <a href="/admin/consult/aktarma/dashbilancojrnl">Bilanço Trend</a></li>
                            <li> <a href="/admin/consult/aktarma/dashrevenuejrnl">Gelir Tablosu Trend</a></li>
                            <li> <a href="/admin/consult/uppageaktarmamzn">Mizan</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </aside>
    <!-- Main Content -->
    @RenderBody()


    <!-- Jquery Core Js -->
    @*
    <script src="/assets/bundles/libscripts.bundle.js"></script>*@     <!-- Lib Scripts Plugin Js -->
    <script src="/assets/bundles/vendorscripts.bundle.js"></script> <!-- Lib Scripts Plugin Js -->
    <script src="/assets/bundles/mainscripts.bundle.js"></script>
    <script src="~/assets/js/sweetalert2.min.js"></script>
    <script src="~/assets/js/toastr.js"></script>
    @RenderSection("Scripts", required: false)
    <script>
        toastr.options = {
            "closeButton": true,
            "debug": false,
            "newestOnTop": true,
            "progressBar": true,
            "maxOpened": 1,
            "positionClass": "toast-top-left",
            "preventDuplicates": true,
            "preventOpenDuplicates": true,
            "onclick": null,
            "showDuration": "3000",
            "hideDuration": "1000",
            "timeOut": "10000",
            "allowHtml": true,
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        }

    </script>

</body>

</html>

