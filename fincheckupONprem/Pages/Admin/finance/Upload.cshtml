@functions {
    public class IndexModel(IUploadMainClient apiClient) : PageModel
    {
        private readonly IUploadMainClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        public FinanceUploadMainRequestInitialModel InitialModel;

        public async Task OnGet()
        {
            try
            { 
                var response = await apiClient.GetAsync(new FinanceUploadMainOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch(Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }


        public async Task<JsonResult> OnGetSalerMainChk(DataSourceLoadOptions options, int monthid)
        {
            try
            {
                var response = await _apiClient.GetSalerMainChkAsync(new FinanceUploadMainOnGetSalerMainChkRequest
                    {
                        options = options,
                        monthid = monthid
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data?.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/Upload OnGetSalerMainChk");
            }
            catch (Exception ex)
