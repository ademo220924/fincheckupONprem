            // return new JsonResult(DataSourceLoader.Load(winModelTlist, options));
            return new JsonResult("Eksik entegrasyon  finance/menu/companyedit/OnGetSalerMain");
        }


        public async Task<JsonResult> OnGetSalerEnteg(DataSourceLoadOptions options)
        {
            try
            {
                var response = await _apiClient.GetSalerEntegAsync(
                    new CompanyEditOnGetSalerEntegRequest
                    {
                        options = options
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/menu/companyedit/OnGetSalerEnteg");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }


            // var mreqListCitiy = Companies.GetCompany_Entegrator();
            // return new JsonResult(DataSourceLoader.Load(mreqListCitiy, options));
