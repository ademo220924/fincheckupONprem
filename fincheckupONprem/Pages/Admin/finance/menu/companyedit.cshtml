        public async Task<JsonResult> OnGetSalerCity(DataSourceLoadOptions options)
        {

            try
            {
                var response = await _apiClient.GetSalerCityAsync(
                    new CompanyEditOnGetSalerCityRequest()
                    {
                        options = options
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/menu/companyedit/OnGetSalerEnteg");
            }
