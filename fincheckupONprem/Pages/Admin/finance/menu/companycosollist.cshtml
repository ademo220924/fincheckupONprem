@using fincheckup.ApiClients.Services.Finance

@model IndexModel
@{
    ViewData["Title"] = "Giriş Ekranı";
    Layout = "~/Pages/Shared/_LayoutFinancea.cshtml";
}


@functions {
    public class IndexModel(IFinanceMenuCompanyKonsolListClient apiClient) : PageModel
    {
       private readonly IFinanceMenuCompanyKonsolListClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
       public CompanyKonsolListInitialModel InitialModel;
        // public int UserID;
        // public HhvnUsers CurrentUser;
        // public IEnumerable<Entities.Company> mreqList;
        // public Company mrequest;

        public async Task OnGet(int id = 0)
        {
            try
            {
                var response = await _apiClient.GetAsync(
                    new CompanyKonsolListOnGetRequest
                    {
                        id = id
                    }, CancellationToken.None);
                
                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                    if (!string.IsNullOrEmpty(response.Data.RedirectUrl))
                        Response.Redirect(response.Data.RedirectUrl);
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }

            // mreqList = new List<Entities.Company>();

            // UserID = Int32.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier));
