            //     Response.Redirect("/admin/finance/menu/companylist");
            // }
            // else
            // {
            //     mrequest = Companies.Get_Company(id);
            //     mreqList = Companies.Get_ConsoleAll(id);
            // }

        }
        public async Task<JsonResult> OnGetKonList(DataSourceLoadOptions options, long ide)
        {
            try
            {
                var response = await _apiClient.GetKonListAsync(
                    new CompanyKonsolListOnGetKonListRequest
                    {
                      options = options,
                      ide = ide
                    }, CancellationToken.None);
               
                if (response.IsSuccess)
                {
                    return response.Data.Response;
                }
              
                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/menu/companyconsollist/OnGetKonList");
               
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
    
            // var winModelTlist = Companies.UpdateStat_Console(ide);
            // return new JsonResult(DataSourceLoader.Load(winModelTlist, options));

        }
