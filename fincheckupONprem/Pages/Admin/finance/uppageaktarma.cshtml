@functions {
    public class IndexModel(IFinanceUpPageAktarmaClient apiClient) : PageModel
    {
        private readonly IFinanceUpPageAktarmaClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        public FinanceUpPageAktarmaRequestInitialModel InitialModel;

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new FinanceUpPageAktarmaOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        
        public async Task<JsonResult> OnGetSalerDateMain(int nyear)
        {
            try
            {
                var response = await _apiClient.GetSalerDateMainAsync(new FinanceUpPageAktarmaOnGetSalerDateMainRequest
                    {
                        nyear = nyear
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return response.Data?.Response;
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/UpPageAktarma OnGetSalerDateMain");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        
        
