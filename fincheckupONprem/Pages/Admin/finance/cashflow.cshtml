@functions {
    public class IndexModel(IFinanceCashFlowClient apiClient) : PageModel
    {
        private readonly IFinanceCashFlowClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        
        public FinanceCashFlowRequestInitialModel InitialModel;

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new FinanceCashFlowOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

