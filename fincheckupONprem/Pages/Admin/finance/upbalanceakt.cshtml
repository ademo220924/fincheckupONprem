@page
@using System.Threading
@using DevExpress.AspNetCore
@using DevExpress.DataAccess.ObjectBinding
@using DevExpress.XtraReports.UI
@using fincheckup.ApiClients.Models.Requests.Finance.UpBalanceAkt
@using fincheckup.ApiClients.Services.Finance
@using fincheckup.Report
@model IndexModel
@{
    ViewData["Title"] = "Report";
    Layout = "~/Pages/Shared/_LayoutReport.cshtml";
}

@functions {
    public class IndexModel(IFinanceUpBalanceAktApiClient apiClient) : PageModel
    {
        private readonly IFinanceUpBalanceAktApiClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        public FinanceUpBalanceAktRequestInitialModel InitialModel;

        public async Task OnGet(int nyear = 2021)
        {
            try
            {
                var response = await _apiClient.GetAsync(new FinanceUpBalanceAktOnGetRequest
                {
                    nyear = 2021
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
    }
}
@section Styles {
    <link rel="stylesheet" href="~/css/viewer.part.bundle.css" />

    <script src="~/js/viewer.part.bundle.js"></script>
    <style>
        .dxrd-toolbar-item-3 {
