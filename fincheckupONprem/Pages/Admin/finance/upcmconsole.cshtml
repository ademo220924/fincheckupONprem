@functions {
    public class IndexModel(IFinanceUpCrmConsoleApiClient apiClient) : PageModel
    {
        private readonly IFinanceUpCrmConsoleApiClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        public FinanceUpCrmConsoleRequestInitialModel InitialModel;

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new FinanceUpCrmConsoleOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }




        public async Task<JsonResult> OnGetSalerDate(DataSourceLoadOptions options)
        {
            try
            {
                var response = await _apiClient.GetSalerDateAsync(new FinanceUpCrmConsoleOnGetSalerDateRequest
                    {
                        options = options
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return response.Data?.Response;
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/upcmconsole OnGetSalerDate");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        
        public async Task<JsonResult> OnGetSalerYear(DataSourceLoadOptions options)
