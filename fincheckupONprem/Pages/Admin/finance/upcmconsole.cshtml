                var response = await _apiClient.GetSalerCompAsync(new FinanceUpCrmConsoleOnGetSalerCompRequest
                    {
                        options = options
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return response.Data?.Response;
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/upcmconsole OnGetSalerComp");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

