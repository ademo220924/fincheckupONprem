        private readonly IFinanceUpPageAktarmaJrnlApiClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient)); 
        public FinanceUpPageAktarmaJrnlRequestInitialModel InitialModel;

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new FinanceUpPageAktarmaJrnlOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        
