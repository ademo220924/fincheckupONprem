        <input type="hidden" style="display:none" id="txtmyear" value="@Model.InitialModel.CurrentUser.SelectedYear" />
        <input type="hidden" style="display:none" id="txtmcomp" value="@Model.InitialModel.CompID" />
        <input type="hidden" style="display:none" id="txtyearcount" value="@Model.InitialModel.YearCount" />
        <input type="hidden" style="display:none" id="txtcompcount" value="@Model.InitialModel.CompCount" />
        <input type="hidden" style="display:none" value="0" id="txtisupdate" />
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12">

                <script>
                    var tyear = $("#txtmyear").val();
                    var mcompid = $("#txtmcomp").val();
                    function onCellPrepared(e) {

                        if (e.columnIndex == 2 && e.rowType == "data") {
                            var chkk = e.data;
                            console.log(parseInt(chkk.TRowCount));
                            if (parseInt(chkk.TRowCount) < 1) {
                                e.cellElement.find(".dx-command-edit").remove();

                                e.cellElement.find(".dx-link-edit").remove();
                            }
                        }

                        if (e.columnIndex == 3 && e.rowType == "data") {
                            var chkk = e.data;

                            if (parseInt(chkk.TRowCount) < 1) {
                                e.cellElement.find(".dx-link-edit").remove();


                            }
                        }

                        if (e.columnIndex == 4 && e.rowType == "data") {
                            var chkk = e.data;

                            if (parseInt(chkk.TRowCount) < 1) {
                                e.cellElement.find(".dx-link-edit").remove();


                            }
                        }
                    }
                    var misready = "nok";
                    var chkReadyState = setInterval(function () {
                        if (document.readyState == "complete") {

                            clearInterval(chkReadyState);

                            misready = "ok";
                        }
                    }, 100);
                    function onRowPrepared(info) {
                        if (info.rowType != "header" && info.data.TxResult == "Bekleniyor") {

                            info.rowElement.addClass("orangecolor");
                        } else if (info.rowType != "header") {
                            info.rowElement.addClass("greencolor");
                        }
                    }
                    var dt1 = "0";
                    var compid = $("#txtmcomp").val();
                    var monthid = 0;
                    var year = $("#txtmyear").val();



                    function getselectYearInstance() {
                        return $("#slctYear").dxSelectBox("instance");
                    }
                    
                    function selectYear_Initialized() {
                        getselectYearInstance().option("value", parseInt($("#txtmyear").val()));
                        var chkco = parseInt($("#txtyearcount").val());

                        //if (chkco < 2) {
                        //    getselectYearInstance().option("readOnly", true);
                        //}


                    }

                   


                  


                    function funcUpload() {
                        $('#uploadInput').focus().trigger('click');
                  /*      $("#griddiv").css("display", "none");*/
                    }





                    var tyear = $("#txtmyear").val();
                    var mcompid = $("#txtmcomp").val();


                    function startit() {
                        getLoadPanelInstance().show();

                    };
                   


                    function functionupdatetax(data) {

                        monthid = data;


                 /*       let elementza = document.getElementById("slctCode");*/
                        let elementz = document.getElementById("grdContYearDefterz");
                        tyear = data;
                        let instancez = DevExpress.ui.dxDataGrid.getInstance(elementz);
                    /*    let instanceza = DevExpress.ui.dxDataGrid.getInstance(elementza);*/
                        instancez.getDataSource().reload();
                   /*     instanceza.getDataSource().reload();*/

                        var selectBoxDataSource = $("#slctCode").dxSelectBox("getDataSource");
                        selectBoxDataSource.reload();
                        $("#griddiv").css("display", "block");
                    }

                    function functionupdatecodezone(data) {
                        console.log(data);
                        var currentValueCode = data;
                        var turl = '/admin/finance/uppageaktarmajrnl?handler=GraphCodeDel&nyear=' + tyear + '&ncode=' + currentValueCode  ;


                        $.ajax({
                            type: "GET",
                            url: turl,
                            contentType: "application/json; charset=utf-8",
                            dataType: "json",
                            success: function (response) {
                                if (response == "ok") {
                                    location.reload();
                                }

                            },
                            failure: function (response) {
                                alert(response);
                            }
                        });

                    }
                    function functionupdatet() {
                        var selectBoxInstanceDC = $("#txtDcVal").dxSelectBox("instance");
                        var selectBoxInstance = $("#slctCode").dxSelectBox("instance");
                        var textBoxInstance = $('#txtVallueNum').dxNumberBox('instance');
                        var currentValue = textBoxInstance.option('value');
                        var currentValueCode = selectBoxInstance.option('value');
                        var currentValueDC = selectBoxInstanceDC.option('value');
                        textBoxInstance.option('value', 0);
                        selectBoxInstance.option('value', 0);

                        if (currentValueDC == null || currentValueDC.length < 1 || currentValue == null || currentValueCode==null  || currentValue.length <4 || currentValueCode.length < 1 ) {
                            Swal.fire(
                                'Hata!',
                                'Muhasebe Kodu Seçilmeli / Değer en az 4 haneli olmalı / De-Cr Belirtilmeli!',
                                'error'
                            )
                            return;
                        }


                        var turl = '/admin/finance/uppageaktarmajrnl?handler=GraphCode&nyear=' + tyear + '&ncode=' + currentValueCode + '&nvalue=' + currentValue + "&ncodedc=" + currentValueDC;


                            $.ajax({
                                type: "GET",
                                url: turl,
                                contentType: "application/json; charset=utf-8",
                                dataType: "json",
                                success: function (response) {
                                    if (response == "ok") {
                                        let elementzz = document.getElementById("grdContYearDefterz");

                                        let instancezz = DevExpress.ui.dxDataGrid.getInstance(elementz);
                                        instancezz.getDataSource().reload();

                                    }

                                },
                                failure: function (response) {
                                    alert(response);
                                }
                            });



                    }

                </script>






                <div class="card">
                    <div class="body">

                        <div class="row">


                            <div class="col-md-12 col-lg-4">
                                <div class="row clearfix">
                                    <div class="col-md-11 col-lg-11">


                                        <div class="card">




                                            <div class="body">

                                                <div class="row">
                                                    @(Html.DevExtreme().DataGrid<YearlyErrorResult>
                                                                            ().ColumnHidingEnabled(true).ID("grdContYearDefter").OnCellPrepared("onCellPrepared").OnRowPrepared("onRowPrepared").ShowColumnLines(false).ShowBorders(false).ColumnAutoWidth(true)
                                                                            .Height(440) .Columns(columns =>
                                                                            {
                                                                            columns.AddFor(m => m.MainYear).Caption("Yıl").CssClass("centerdiv") ;
                                                                            columns.AddFor(m => m.MainMonth).Visible(false).SortOrder(SortOrder.Asc);

                                                                            columns.Add().CssClass("").Caption("Aksiyon").CellTemplate(@<text>
                                                                                <div onclick="functionupdatetax('[%= data.MainYear %]')" class="dxmain dx-link-edit dx-button dx-button-normal dx-button-mode-contained dx-widget dx-button-has-text" aria-label="Yükle" tabindex="0" role="button"><div class="dx-button-content"><span class="dx-button-text">Journal Form Oluştur</span></div></div> </text>);
                                                                            columns.AddFor(m => m.TRowCount).Visible(false);

                                                                            }).DataSource(d => d.RemoteController().LoadUrl(Url.Page(null, "SalerDate"))
                                                                            ))


                                                </div>



                                            </div>
                                        </div>
                                    </div>

                                </div>



                            </div>
                            <div class="col-md-12 col-lg-8">
                                <div class="row clearfix">
                                    <div class="col-md-11 col-lg-11">


                                        <div class="card" id="griddiv" style="display:none">
                                            <div class="body">
                                                <div class="row">
                                                    <div class="col-4">
                                                        @(Html.DevExtreme().SelectBox().SearchEnabled(true)
                        .DataSource(d => d.RemoteController().LoadUrl(Url.Page(null, "SalerDateCode")).LoadParams(new { nyear = new JS("function() {return tyear; }"), compid = new JS("function() {return mcompid; }") })).ID("slctCode")
                    .DisplayExpr("AccountMainDescription")
                    .ValueExpr("AccountMainID").Width(205).Height(29)
                )
                                                    </div>
                                                    <div class="col-3">
                                                        @(Html.DevExtreme().NumberBox().Min(0)
                    .Placeholder("Değeri girin").Width(155).Height(29).ID("txtVallueNum")

                )
                                                    </div>
                                                    <div class="col-2">

                                                        @(Html.DevExtreme().SelectBox().DataSource(Model.InitialModel.mDcResult)
                    .Width(85).Height(29).ID("txtDcVal").DisplayExpr("MText").Value("Debit").ValueExpr("MVal")

                )
                                                    </div>
                                                    <div class="col-3">
                                                        @(Html.DevExtreme().Button()
.Text("İşle")
.Type(ButtonType.Default).Width(155).Height(29)
.StylingMode(ButtonStylingMode.Contained)
.Width(120).OnClick("functionupdatet")
                    )
                                                    </div>
                                                </div>


                                                <div class="row">
                                                    @(Html.DevExtreme().DataGrid<TblxmJournalFile>
                                                                            ().ColumnHidingEnabled(true).ID("grdContYearDefterz").OnInitialized("onInitializedgrid").ShowColumnLines(false)
    .ColumnMinWidth(50)
    .ColumnAutoWidth(true).ShowBorders(false)
                                                                            .Height(440) .Columns(columns =>
                                                                            {

                                                                            columns.AddFor(m => m.Id).Visible(false);
                                                                            columns.AddFor(m => m.AccountMainId).Caption("Hesap Kodu");
                                                                            columns.AddFor(m => m.Amount).Caption("Tutar").Format(Format.FixedPoint); columns.AddFor(m => m.DebitCredit).Caption("Debit/Credit");
                                                                            columns.Add().CssClass("").Caption("SİL").CellTemplate(@<text>
                                                                                <div onclick="functionupdatecodezone('[%= data.AccountMainID %]')" class="dxmain dx-link-edit dx-button dx-button-normal dx-button-mode-contained dx-widget dx-button-has-text" aria-label="Yükle" tabindex="0" role="button"><div class="dx-button-content"><span class="dx-button-text">SİL</span></div></div>


                                                                            </text>);
                                                                            }) .DataSource(d => d.RemoteController().LoadUrl(Url.Page(null, "SalerDateMain")).LoadParams(new { nyear = new JS("function() {return tyear; }"), compid = new JS("function() {return mcompid; }") }))
                                                                            )
                                                </div>

                                                <input type="text" id="selectedItemsContainer" name="selectedItemsContainer" style="display:none" />
                                            </div>
                                        </div>
                                    </div>

                                </div>



                            </div>

                        </div>



                    </div>

                </div>
            </div>

        </div>



    </div>
</section>
@(Html.DevExtreme().LoadPanel()
                    .ID("loadPanel")
