@section Scripts{
    <script src="~/js/polyfill.min.js"></script>

    <script>
        function selectrep_valuexls(data) {



            var turl = '/admin/finance/upreportmain?handler=CheckRepXls&nyear=@Model.InitialModel.YearCurrent&companyID=@Model.InitialModel.curcomID&nmonth=' + data;


            getLoadPanelInstance().show();
            $.ajax({
                type: "GET",
                url: turl,
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {



                    getLoadPanelInstance().hide();
                    console.log(response);

                    if (response == "nok") {
                        Swal.fire(
                            'Uyarı!',
                            'Hata Kaydı Bulunamadı!',
                            'error'
                        )
                        return;
                    }
                    else {


                        var chkdomain = $(location).attr('host');


                        const myArray = response.split("/");
                        let word = myArray[1];
                        var url = 'https://' + chkdomain + '/' + response;
                        // window.location.href = 'https://' + chkdomain + response;
                        console.log(url);
                        var link = document.createElement('a');
                        link.href = url;
                        link.download = word;
                        link.dispatchEvent(new MouseEvent('click'));
                    }



                },
                failure: function (response) {
                    alert(response);
                }
            });


        }
        function selectrep_valuepdf(data) {


            var turl = '/admin/finance/upreportmain?handler=CheckRepPdf&nyear=' + data + '&companyID=@Model.InitialModel.curcomID&nmonth=' + 0;


