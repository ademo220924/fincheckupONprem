@functions {
    public class IndexModel(IFinanceUpPageAktarmaMznClient apiClient) : PageModel
    {
        private readonly IFinanceUpPageAktarmaMznClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        public FinanceUpPageAktarmaMznRequestInitialModel InitialModel;

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new FinanceUpPageAktarmaMznOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data?.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        
        public async Task<JsonResult> OnGetSalerDateMain(int nyear)
        {
            try
            {
                var response = await _apiClient.GetSalerDateMainAsync(new FinanceUpPageAktarmaMznOnGetSalerDateMainRequest
                    {
                        nyear = nyear
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return response.Data?.Response;
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/UpPageAktarmaMzn OnGetSalerDateMain");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        

