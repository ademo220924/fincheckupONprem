        $("#exportGrids").dxButton({
            text: "Excel Raporu",
            onClick: function () {
                var dataGrid1 = $("#pivotgrid").dxPivotGrid("instance");
                var dataGrid2 = $("#pivotgrida").dxPivotGrid("instance");
                var workbook = new ExcelJS.Workbook();
                var worksheet = workbook.addWorksheet('Main sheet');

                Object.assign(
                    worksheet.getRow(2).getCell(2),
                    { value: "AKTİFLER", font: { bold: true, size: 16, underline: 'double' } }
                );
                Object.assign(
                    worksheet.getRow(2).getCell(iNum),
                    { value: "PASİFLER", font: { bold: true, size: 16, underline: 'double' } }
                );

                DevExpress.excelExporter.exportPivotGrid({
                    worksheet,
                    component: dataGrid1,
                    topLeftCell: { row: 4, column: 2 }
                }).then(function (dataGridRange) {
                    return DevExpress.excelExporter.exportPivotGrid({
                        worksheet,
                        component: dataGrid2,
                        topLeftCell: { row: 4, column: (dataGridRange.to.column + 2) }
                    });
                }).then(function () {
                    workbook.xlsx.writeBuffer().then(function (buffer) {
                        saveAs(new Blob([buffer], { type: "application/octet-stream" }), "BalanceSheet.xlsx");
                    });
                });
            }
        });

