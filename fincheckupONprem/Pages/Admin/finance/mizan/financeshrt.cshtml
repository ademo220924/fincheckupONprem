@section Styles {
    <link rel="stylesheet" href="/assets/plugins/jquery-datatable/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="/assets/plugins/morrisjs/morris.css">
    <style>
        .tdnormall {
            padding-top: 0.1rem !important;
            padding-left: 0.75rem !important;
            padding-bottom: 0.1rem !important;
            padding-right: 0.75rem !important;
        }

        #chartxt {
            max-height: 255px !important;
        }

        #pivotgrid td {
            vertical-align: middle;
        }

        #pivotgrid .chart-cell {
            overflow: visible;
        }

        #pivotgrid .current-value {
            display: inline-block;
        }

        #pivotgrid .diff {
            position: relative;
            display: table-cell;
            font-size: 16px;
        }

        #pivotgrid .inc .diff {
            color: #2ab71b;
        }

        #pivotgrid .inc .diff:before {
                content: '+';
            }

        #pivotgrid .dec .diff:before {
            content: '-';
        }

        #pivotgrid .dec .diff {
            color: #f00;
        }

            #pivotgrid .inc .diff:after,
        #pivotgrid .dec .diff:after {
                content: '';
                display: block;
                height: 10px;
                width: 10px;
                position: absolute;
                right: -12px;
                top: 6px;
                background-repeat: no-repeat;
                background-size: 10px 10px;
            }

        #pivotgrid .inc .diff:after {
            background-image: url('data:image/png;base64,');
        }

        #pivotgrid .dec .diff:after {
            background-image: url('data:image/png;base64,');
        }
    </style>
}
<section class="content home" id="employee">
    @(Html.DevExtreme().LoadPanel()
        .ID("loadPanel")
        .ShadingColor("rgba(0,0,0,0.4)")
        .Position(p => p.Of("#employee"))
        .Visible(false)
        .ShowIndicator(true)
        .ShowPane(true)
        .Shading(true)
        .HideOnOutsideClick(false)
        .OnShown("loadPanel_shown")
        )

    <input type="hidden" style="display:none" id="txtmyear" value="@Model.InitialModel.CurrentUser.SelectedYear" />
    <input type="hidden" style="display:none" id="txtmcomp" value="@Model.InitialModel.CompID" />
    <input type="hidden" style="display:none" id="txtyearcount" value="@Model.InitialModel.YearCount" />
    <input type="hidden" style="display:none" id="txtcompcount" value="@Model.InitialModel.CompCount" />
    <div class="container-fluid">
        <div class="block-header">
            <div class="row clearfix">
                <div class="col-lg-5 col-md-5 col-sm-12">
                    <h2>Bilanço</h2>
                    <ul class="breadcrumb padding-0">
                        <li class="breadcrumb-item"><a href=""><i class="zmdi zmdi-home"></i></a>Gelir Tablosu</li>
                        <li class="breadcrumb-item active">Revenue</li>
                    </ul>
                </div>
                <div class="col-lg-7 col-md-7 col-sm-12">
                    <div class="input-group m-b-0">
                        <div class="col-12">
                            <div class="card">
                                <div class="body">
                                    <div class="row">
                                        
                                        <div class="col-6" style="text-align:left">

                                            <div id="exportGrids"></div>
                                        </div>
                                        <div class="col-6" style="text-align: right  ">

                                            
                                            @(Html.DevExtreme().TextBox()
                                                .Value(Model.InitialModel.CompName).ReadOnly(true)
                                                )

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">

            <div class="col-md-12 col-lg-12">
                <div class="card">
                    <div class="body">

                        <div class="row">
                             
                            <div class="col-md-12 col-lg-12">
                                <div class="row clearfix">
                                    <div class="col-md-6 col-lg-6">
                                        <div class="card">
                                            <div class="body">
                                                <div class="row">

                                                    @(Html.DevExtreme().PivotGrid<DashPivotView>()
                                                        .ID("pivotgrid")
                                                        .AllowSortingBySummary(true)
                                                        .AllowFiltering(true)
                                                        .ShowBorders(true).AllowExpandAll(true)
                                                        .ShowColumnGrandTotals(false).AllowExpandAll(true)
                                                        .ShowRowGrandTotals(false)
                                                        .ShowRowTotals(false) 
                                                        .OnCellPrepared("cell_prepared")
                                                        .ShowColumnTotals(false).FieldChooser(fc => fc
                                                        .AllowSearch(false)
                                                        .ApplyChangesMode(ApplyChangesMode.Instantly)).FieldPanel(e => e.ShowColumnFields(true).ShowDataFields(false).ShowFilterFields(false).ShowRowFields(false))

                                                        .DataSource(d => d
                                                        .Store(s => s.RemoteController().LoadUrl(Url.Page(null, "MarkupMarjinA")).LoadParams(new { compid = new JS("function() {return mcompid; }") }))
                                                        .Fields(fields =>
                                                        {
                                                            fields.AddFor(m => m.GroupName)
                                                            .Width(170)
                                                            .Area(PivotGridArea.Row).Expanded(true).Visible(false)
                                                            ; fields.AddFor(m => m.CounterZone)
                                                            .Width(120)
                                                            .Area(PivotGridArea.Row).SortBy(PivotGridSortBy.Value).Visible(false)
                                                            ;
                                                            fields.AddFor(m => m.AccountMainDescription)
                                                            .Width(170)
                                                            .Area(PivotGridArea.Row).SortBy(PivotGridSortBy.None).AllowFiltering(false)
                                                            ;
                                                      
                                                            fields.AddFor(m => m.Year).SortBy(PivotGridSortBy.Value).Area(PivotGridArea.Column).Expanded(true);
                                                            
                                                            fields.AddFor(m => m.Amount)
                                                            .SummaryType(SummaryType.Sum).Caption("Değer")
                                                            .DataType(PivotGridDataType.Number).Format(x => x.Precision(1)).Format(Format.FixedPoint)
                                                            .Area(PivotGridArea.Data);
                                                            fields.AddFor(m => m.Diff).SummaryType(SummaryType.Sum).Width(9)
                                                            .DataType(PivotGridDataType.Number).Format(x => x.Precision(1)).Caption("Oran(%)")
                                                            .Area(PivotGridArea.Data);
                                                        })
                                                        )
                                                        )



                                                </div>


                                            </div>
                                        </div>


                                    </div>
                                    <div class="col-md-6 col-lg-6">
                                        <div class="card">
                                            <div class="body">
                                                <div class="row">

                                                    @(Html.DevExtreme().PivotGrid<DashPivotView>()
                                                        .ID("pivotgrida")
                                                        .AllowSortingBySummary(true)
                                                        .AllowFiltering(true)
                                                        .ShowBorders(true).AllowExpandAll(true)
                                                        .ShowColumnGrandTotals(false).AllowExpandAll(true)
                                                        .ShowRowGrandTotals(false)
                                                        .ShowRowTotals(false) 
                                                        .OnCellPrepared("cell_prepared")
                                                        .ShowColumnTotals(false).FieldChooser(fc => fc
                                                        .AllowSearch(false)
                                                        .ApplyChangesMode(ApplyChangesMode.Instantly)).FieldPanel(e => e.ShowColumnFields(true).ShowDataFields(false).ShowFilterFields(false).ShowRowFields(false))

                                                        .DataSource(d => d
                                                        .Store(s => s.RemoteController().LoadUrl(Url.Page(null, "MarkupMarjinB")).LoadParams(new { compid = new JS("function() {return mcompid; }") }))
                                                        .Fields(fields =>
                                                        {
                                                            fields.AddFor(m => m.GroupName)
                                                            .Width(170).Visible(false)
                                                            .Area(PivotGridArea.Row).Expanded(true)
                                                            ; fields.AddFor(m => m.CounterZone)
                                                            .Width(120)
                                                            .Area(PivotGridArea.Row).SortBy(PivotGridSortBy.Value).Visible(false)
                                                            ;
                                                            fields.AddFor(m => m.AccountMainDescription)
                                                            .Width(170)
                                                            .Area(PivotGridArea.Row).SortBy(PivotGridSortBy.None).AllowFiltering(false)
                                                            ;

                                                            fields.AddFor(m => m.Year).SortBy(PivotGridSortBy.Value).Area(PivotGridArea.Column).Expanded(true);

                                                            fields.AddFor(m => m.Amount)
                                                            .SummaryType(SummaryType.Sum).Caption("Değer")
                                                            .DataType(PivotGridDataType.Number).Format(x => x.Precision(1)).Format(Format.FixedPoint)
                                                            .Area(PivotGridArea.Data);
                                                            fields.AddFor(m => m.Diff).SummaryType(SummaryType.Sum).Width(9)
                                                            .DataType(PivotGridDataType.Number).Format(x => x.Precision(1)).Caption("Oran(%)")
                                                            .Area(PivotGridArea.Data);
                                                        })
                                                        )
                                                        )



                                                </div>


                                            </div>
                                        </div>


                                    </div>
                                </div>



                            </div>

                        </div>



                    </div>

                </div>

            </div>




        </div>





    </div>
</section>


