@model IndexModel
@{
    ViewData["Title"] = "Giriş Ekranı";
    Layout = "~/Pages/Shared/_LayoutFinanceMzn.cshtml";
}
@using fincheckup.ApiClients.Models.Requests.Finance.Mizan.Menu.CompanyKonsol
@using fincheckup.ApiClients.Services.Finance

@functions {
    public class IndexModel(IFinanceMizanMenuCompanyKonsolClient apiClient) : PageModel
    {
