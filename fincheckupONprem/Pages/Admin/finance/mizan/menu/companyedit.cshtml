@section Scripts{
 

    <script>

        var dt1 = "105";

        $("#frm").submit(function () {
            var vals = $(this).serialize();



            $.ajax({
                url: "/JsonService/MainPost/FormSubmitCompany",
                method: "POST",
                data: vals,
                success: function (data) {

                    console.log(data);
                    if (data == -1) { alert("Bu VKN ile daha önce Kayıt Yapılmış. Yeni Kaydı Yapılamaz"); }
                    else { location.href = "/admin/finance/mizan/menu/companylist"; }
                }
            });

            return false; // prevent from submit
        });

         function functionrefresh(data) {
            var chk = "@Model.InitialModel.mrequest.Id";

            if (chk == "0") {
                alert("Ana Firma Kaydı Tamamlanmadan Bu İşlem Gerçekleştirilemez");
            }
            else {
                location.href = "/admin/finance/mizan/menu/companycosollist?id=@Model.InitialModel.mrequest.Id";
            }
            //alert(data);


        }
    </script>
