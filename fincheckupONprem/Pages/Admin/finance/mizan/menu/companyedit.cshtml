        // public int CQuestions { get; set; }
        
        public MizanCompanyEditRequestInitialModel InitialModel;
        
        public async Task OnGet(int id = 0)
        {
            var response = await companyEditClient.GetAsync(new MizanCompanyEditOnGetRequest()
            {
                id = id
            }, CancellationToken.None);

            try
            {
                InitialModel = response.Data.InitialModel;
            }
            catch
            {
                Console.WriteLine(response.ProblemDetails.Detail);
                throw;
            } 
            //
            //
            // if (id == 0)
            // {
            //     mrequest = new Companies();
            //
            //     UserID = Int64.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier));
            //     CurrentUser = HhvnUsers.GetRow_User(UserID);
            //      
            //
            // }
            // else
            // {
            //     mrequest = Companies.Get_Company(id);
            // }

        }

        public JsonResult OnGetSalerMain(DataSourceLoadOptions options, string dt1)
        {
            // dt1 = "105";
            // var winModelTlist = Data.Get_AllbyCsvID(dt1);
            // return new JsonResult(DataSourceLoader.Load(winModelTlist, options));
            return new JsonResult("Entegrasyon yapılmadı - admin/finance/mizan/menu/companyedit OnGetSalerMain");
        }
       
  
        public async Task<IActionResult> OnGetSalerEnteg(DataSourceLoadOptions options)
        {
            try
            {
                var response = await companyEditClient.GetSalerEntegAsync(
                    new MizanCompanyEditOnGetSalerEntegRequest { options = options },
                    CancellationToken.None);

                if (response.IsSuccess && response.Data?.Response is JsonElement loadEnteg)
                {
                    return Content(loadEnteg.GetRawText(), "application/json");
                }

                Console.WriteLine(response.ProblemDetails?.Detail);
                return new JsonResult("Burada hata var mizan/menu/companyedit OnGetSalerEnteg");
            }
            catch (ApiException ex)
            {
                Console.WriteLine(ex.Message);
                return new JsonResult(new { error = ex.Message, detail = ex.Content });
            }
        }

        public async Task<IActionResult> OnGetSalerCity(DataSourceLoadOptions options)
        {
            try
            {
                var response = await companyEditClient.GetSalerCityAsync(
                    new MizanCompanyEditOnGetSalerCityRequest { options = options },
                    CancellationToken.None);

                if (response.IsSuccess && response.Data?.Response is JsonElement loadCity)
                {
                    return Content(loadCity.GetRawText(), "application/json");
                }

                Console.WriteLine(response.ProblemDetails?.Detail);
                return new JsonResult("Burada hata var mizan/menu/companyedit OnGetSalerCity");
            }
            catch (ApiException ex)
            {
                Console.WriteLine(ex.Message);
                return new JsonResult(new { error = ex.Message, detail = ex.Content });
            }
        }

    }
}
