<input type="text" id="mainyear" name="mainyear" value="@Model.InitialModel.CurrentUser.SelectedYear" style="display:none" />
<input type="text" id="mainmonth" name="mainmonth" style="display:none" />




@section Scripts {
    <script src="~/js/polyfill.min.js"></script>

    <script>
        function buildMizanFileDownloadUrl(response) {
            var raw = response;
            if (response && typeof response === "object") {
                if (response.value !== undefined)
                    raw = response.value;
                else if (response.fileUrl !== undefined)
                    raw = response.fileUrl;
                else
                    raw = "";
            }
            if (typeof raw === "string" && raw.length > 0 && raw.charAt(0) === "{") {
                try {
                    var j = JSON.parse(raw);
                    raw = j.value || j.url || raw;
                } catch (e) { }
            }
            if (!raw || typeof raw !== "string")
                return "";
            raw = raw.replace(/\\/g, "/");
            if (raw.indexOf("http://") === 0 || raw.indexOf("https://") === 0)
                return raw;
            var base = ($("#hidPublicFileBaseUrl").val() || "").trim().replace(/\/$/, "");
            if (base)
                return base + "/" + raw.replace(/^\//, "");
            return window.location.protocol + "//" + $(location).attr("host") + "/" + raw.replace(/^\//, "");
        }

        function selectrep_valuexls(data) {



            var turl = '/admin/finance/mizan/upbalancenew?handler=CheckRepXls&nyear=' + $("#txtmyear").val() + '&companyID=' + $("#txtcurcomide").val() + '&nmonth=' + data;


            getLoadPanelInstance().show();
            $.ajax({
                type: "GET",
                url: turl,
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {



                    getLoadPanelInstance().hide();
                    console.log(response);

                    if (response == "nok") {
                        Swal.fire(
                            'Uyarı!',
                            'Hata Kaydı Bulunamadı!',
                            'error'
                        )
                        return;
                    }
                    else {
                        var url = buildMizanFileDownloadUrl(response);
                        if (!url) {
                            Swal.fire('Uyarı!', 'Dosya yolu alınamadı.', 'error');
                            return;
                        }
                        window.open(url, "_blank");
                    }

                },
                failure: function (response) {
                    alert(response);
                }
            });


        }
        function selectrep_valuepdf(data) {


            var turl = '/admin/finance/mizan/upbalancenew?handler=CheckRepPdf&nyear=' + data + '&companyID=' + $("#txtcurcomide").val() + '&nmonth=' + 0;


            getLoadPanelInstance().show();
            $.ajax({
                type: "GET",
                url: turl,
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {


                    getLoadPanelInstance().hide();
                    console.log(response);

                    if (response == "nok") {
                        Swal.fire(
                            'Uyarı!',
                            'Hata Kaydı Bulunamadı!',
                            'error'
                        )
                        return;
                    }
                    else {
                        var url = buildMizanFileDownloadUrl(response);
                        if (!url) {
                            Swal.fire('Uyarı!', 'Dosya yolu alınamadı.', 'error');
                            return;
                        }
                        window.open(url, "_blank");
                    }

                },
                failure: function (response) {
                    alert(response);
                }
            });


        }
        function getLoadPanelInstance() {
            return $("#loadPanel").dxLoadPanel("instance");
        }
        function loadPanel_shown(e) {
            setTimeout(function () {
                e.component.hide();
            }, 610000);
        }


        var txcompname = $("#txtcompname").val();

        function formatMessage(e) {

            return $("#txtcompname").val();
        }



    </script>

}
