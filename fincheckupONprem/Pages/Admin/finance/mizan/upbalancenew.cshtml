                    function funcUpload() {
                        $('#uploadInput').focus().trigger('click');
                        $("#griddiv").css("display", "none");
                    }

                    function startit() {
                        getLoadPanelInstance().show();

                    };

                    function onGrdContYearDefterCellClick(e) {
                        if (e.rowType !== "data" || !e.column) return;
                        var caption = String(e.column.caption || "").trim();
                        var d = e.data || {};
                        var y = Number(d.mainYear != null ? d.mainYear : d.MainYear);
                        var m = Number(d.mainMonth != null ? d.mainMonth : d.MainMonth);
                        if (isNaN(y)) y = parseInt(String($("#txtmyear").val()), 10) || 0;
                        if (isNaN(m)) m = 0;
                        if (caption === "Aksiyon") {
                            functionupdatetax(y, m);
                        } else if (caption === "Rapor Çıktısı") {
                            if (typeof selectrep_valuepdf === "function") {
                                selectrep_valuepdf(y);
                            }
                        }
                    }

                    function functionupdatetax(mainYear, mainMonth) {
                        startit();
                        var y = parseInt(String(mainYear != null && mainYear !== '' ? mainYear : $("#txtmyear").val()), 10);
                        var m = parseInt(String(mainMonth != null && mainMonth !== '' ? mainMonth : 0), 10);
                        if (isNaN(y)) { y = parseInt(String($("#txtmyear").val()), 10) || 0; }
                        if (isNaN(m)) { m = 0; }
                        monthid = m;
                        var fdatam = new FormData();
                        var compId = $("#txtcurcomide").val() || $("#txtmcomp").val() || "0";
                        fdatam.append('caplist', '');
                        fdatam.append('companyid', compId);
                        fdatam.append('month', m);
                        fdatam.append('year', y);

                        $.ajax({
                            url: "/JsonService/Mizan/moodUpdateBalance",
                            method: "POST",
                            statusCode: {
                                500: function () {
                                    getLoadPanelInstance().hide();
                                    Swal.fire({
                                        title: 'Server Erişim Sorunuz. Lütfen Sayfayı Yenileyiniz...',
                                        confirmButtonText: 'Yenile'
                                    }).then((result) => {
                                        /* Read more about isConfirmed, isDenied below */
                                        if (result.isConfirmed) {

                                            location.reload();
                                        }
                                    });
                                },
                                404: function () {
                                    alert("Script 404");
                                }
                            },
                            contentType: false,
                            data: fdatam,
                            processData: false,
                            cache: false,
                            success: function (data) {
                                getLoadPanelInstance().hide();
                                if (data == "nok") {

                                    Swal.fire(
                                        'Hata!',
                                        'Hata ile Karşılaşıldı!',
                                        'error'
                                    )
                                }
                                else {
                                    var arr = data.split('_');

                                    dt1 = arr[0];

                                    Swal.fire(
                                        'Başarılı!',
                                        'Güncelleme Tamamlandı!',
                                        'success'
                                    )
                                    setTimeout(function () {
                                        location.reload();
                                    }, 2000);


                                }


                            }
                        });


                    }

                </script>





