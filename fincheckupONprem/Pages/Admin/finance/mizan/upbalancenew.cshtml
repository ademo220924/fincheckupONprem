@model IndexModel
@{
    ViewData["Title"] = "Giriş Ekranı";
    Layout = "~/Pages/Shared/_LayoutFinanceMzn.cshtml";
}

@functions {
    public class IndexModel(
        IFinanceMizanUpBalanceNewClient apiClient,
        IFinanceMizanUpBalanceClient mizanUpBalanceClient,
        IOptions<PublicFileHostingSettings> publicFileHosting) : PageModel
    {
        private readonly IFinanceMizanUpBalanceNewClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        private readonly IFinanceMizanUpBalanceClient _mizanUpBalanceClient = mizanUpBalanceClient ?? throw new ArgumentNullException(nameof(mizanUpBalanceClient));
        private readonly PublicFileHostingSettings _publicFiles = publicFileHosting?.Value ?? new PublicFileHostingSettings();

        public MizanUpBalanceNewRequestInitialModel InitialModel{ get; set; }

        public string PublicFileBaseUrl => (_publicFiles.BaseUrl ?? string.Empty).TrimEnd('/');

        private static string NormalizeMizanRelativePath(string? path)
        {
            if (string.IsNullOrWhiteSpace(path))
                return string.Empty;
            return path.Trim().TrimStart('/', '\\').Replace('\\', '/');
        }

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new MizanUpBalanceNewOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data.InitialModel;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails.Detail);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

        public async Task<JsonResult> OnGetSalerDate(DataSourceLoadOptions options)
        {
            try
            {
                await OnGet();
                var response = await _apiClient.GetSalerDateAsync(new MizanUpBalanceNewOnGetSalerDateQuery
                { 
                    Request= new MizanUpBalanceNewOnGetSalerDateRequest(){options = options},
                    InitialModel = InitialModel,
                    UserId=InitialModel.UserID.ToString()
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/mizan/upbalancenew OnGetSalerDate");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

        public async Task<JsonResult> OnGetSalerYear(DataSourceLoadOptions options)
        {
            try
            {
                await OnGet();
                var response = await _apiClient.GetSalerYearAsync(new MizanUpBalanceNewOnGetSalerYearRequest
                {
                    options = options
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/mizan/upbalancenew OnGetSalerYear");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

        public async Task<JsonResult> OnGetSalerComp(DataSourceLoadOptions options)
        {
            try
            {
                var response = await _apiClient.GetSalerCompAsync(new MizanUpBalanceNewOnGetSalerCompQuery
                { Request = new MizanUpBalanceNewOnGetSalerCompRequest(){options= options}
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/mizan/upbalancenew OnGetSalerComp");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

        public async Task<JsonResult> OnGetCheckRepPdf(long companyID, int nyear)
        {
            try
            {
                await OnGet();
                var response = await _apiClient.GetCheckRepPdfAsync(new MizanUpBalanceNewOnGetCheckRepPdfQuery
                {
                    Request = new MizanUpBalanceNewOnGetCheckRepPdfRequest()
                    {
                    companyID = companyID,
                    nyear = nyear 
                    },
                    InitialModel = InitialModel
                 
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    InitialModel = response.Data!.InitialModel;
                    var rel = NormalizeMizanRelativePath(response.Data.Response);
                    if (string.IsNullOrEmpty(rel))
                        return new JsonResult("nok");
                    // Göreli yol: tarayıcıda buildMizanFileDownloadUrl + hidPublicFileBaseUrl ile tam URL (reportmaintestmizan funczone ile aynı fikir).
                    return new JsonResult(rel);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/mizan/upbalancenew OnGetCheckRepPdf");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

        public async Task<JsonResult> OnGetCheckRepXls(long companyID, int nyear)
        {
            try
            {
                await OnGet();
                var response = await _apiClient.GetCheckRepXlsAsync(new MizanUpBalanceNewOnGetCheckRepXlsRequest
                {
                    companyID = companyID,
                    nyear = nyear
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    var rel = NormalizeMizanRelativePath(response.Data.Response);
                    if (string.IsNullOrEmpty(rel))
                        return new JsonResult("nok");
                    return new JsonResult(rel);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/mizan/upbalancenew OnGetCheckRepXls");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }

        public JsonResult OnGetGraphComp(int ncompid)
        {
            return new JsonResult("Entegrasyon eksik finance/mizan/upbalancenew OnGetGraphComp");
        }

        public async Task<JsonResult> OnGetGraphYear(int nyear)
        {
            try
            {
                var response = await _mizanUpBalanceClient.GetGraphYearAsync(new MizanUpBalanceOnGetGraphYearRequest
                {
                    nyear = nyear
                }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/mizan/upbalancenew OnGetGraphYear");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
    }
}
