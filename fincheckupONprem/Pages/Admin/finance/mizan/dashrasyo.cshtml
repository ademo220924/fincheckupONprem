                        @(Html.DevExtreme().Chart()
        .ID("pivotgrid-chart")
        .CommonSeriesSettings(s => s.Type(SeriesType.Bar))
        .Tooltip(t => t.Enabled(true)
        .Format(Format.Millions)
        .CustomizeTooltip(@<text>
            function (arg) {

                return {
                    text: arg.seriesName + "<br />" + arg.valueText
                };
            }
        </text>
    ).Format(Format.Decimal))
        .Size(s => s.Height(200))
        .AdaptiveLayout(l => l.Width(450))
    )
                        @(Html.DevExtreme().PivotGrid<DashYearlyResultMizan>()
        .ID("pivotgrid")
        .AllowSortingBySummary(true)
        .AllowFiltering(true)
        .ShowBorders(true)
        .ShowColumnGrandTotals(false).AllowExpandAll(true)
        .ShowRowGrandTotals(false)
        .ShowRowTotals(false)
        .ShowColumnTotals(false)
        .FieldChooser(c => c.Enabled(false).Height(400))
        .DataSource(d => d
            .Store(s => s.RemoteController().LoadUrl(Url.Page(null, "ChartRasyo")))
            .Fields(fields => {
                fields.AddFor(m => m.Description)
                    .Width(120)
                    .Area(PivotGridArea.Row)
                    ;
                fields.AddFor(m => m.Year).SortBy(PivotGridSortBy.Value).Area(PivotGridArea.Column).Expanded(true);

                fields.AddFor(m => m.Amount)
                    .SummaryType(SummaryType.Max)
                    .Format("#0.00")
                    .Area(PivotGridArea.Data);
            })
        )
        .OnInitialized("bind_chart")
    )

                        <script>

                            function bind_chart(e) {
                                e.component.bindChart($("#pivotgrid-chart"), {
                                    dataFieldsDisplayMode: "splitPanes",
                                    alternateDataFields: false
                                });

                            }

                        </script>
