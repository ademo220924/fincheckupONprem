@section Scripts{
    <script>
        var tyear = $("#txtmyear").val();
        var mcompid = $("#txtmcomp").val();

        function changeInnerHtml(elementPath, newText) {
            $(elementPath).fadeOut(500, function () {
                $(this).html(newText).fadeIn(500);
            });
        }
        window.onmouseover = function (e) {
            if (e.target.className =="dx-last-cell") {

               /* $("").toggleClass("").siblings().removeClass("open stretchRight");*/

                if ($(".right_menu #rightsidebar").hasClass("open stretchRight") == false) {

                    $(".right_menu #rightsidebar").toggleClass("open stretchRight").siblings().removeClass("open stretchRight");
                }

                //$("#txtool").val(e.target.innerText);


