@section Scripts{
    <script src="/js/a_poly.js"></script>
    <script src="/js/a_excel.js"></script>
    <script src="/js/a_filesave.js"></script>

    <script>
        function onExporting(e) {
            var workbook = new ExcelJS.Workbook();
            var worksheet = workbook.addWorksheet('konsolide bilanco');

            DevExpress.excelExporter.exportPivotGrid({
                component: e.component,
                worksheet: worksheet
            }).then(function () {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: 'application/octet-stream' }), 'konsolidebilanco.xlsx');
                });
            });
            e.cancel = true;
        }
    </script>

    <script>
        var konsolPageUrl = @Json.Serialize(Url.Page("/Admin/finance/mizan/konsol/dashbilancokon"));
        var tyear = $("#txtmyear").val();
        var mcompid = $("#txtmcomp").val();

        function getLoadPanelInstance() {
            return $("#loadPanel").dxLoadPanel("instance");
        }
        function hideLoadPanelSafe() {
            try {
                var el = $("#loadPanel");
                if (!el.length) return;
                var inst = el.dxLoadPanel("instance");
                if (inst) inst.hide();
            } catch (e) { /* widget henüz yok */ }
        }
        function loadPanel_shown(e) {
            setTimeout(function () {
                try { e.component.hide(); } catch (err) { }
            }, 7000);
        }
        var misready = "nok";
        var chkReadyState = setInterval(function () {
            if (document.readyState == "complete") {

                clearInterval(chkReadyState);

                misready = "ok";
            }
        }, 100);

        function getselectYearInstance() {
            return $("#slctYear").dxSelectBox("instance");
        }
        function getselectCompInstance() {
            return $("#slctCompany").dxSelectBox("instance");
        }
        function selectYear_Initialized() {
            getselectYearInstance().option("value", parseInt($("#txtmyear").val()));
            var chkco = parseInt($("#txtyearcount").val());

            if (chkco < 2) {
                getselectYearInstance().option("readOnly", true);
            }


        }

        function selectComp_Initialized() {

            var chkco = parseInt($("#txtcompcount").val());
            getselectCompInstance().option("value", parseInt($("#txtmcomp").val()));

            if (chkco < 2) {
                getselectCompInstance().option("readOnly", true);
            }
        }


        function selectYear_valueChanged(data) {
            var slctval = data.selectedItem.MYear;
            var turl = konsolPageUrl + "?handler=GraphYear&nyear=" + encodeURIComponent(slctval);

            if (misready == "ok" && tyear.toString() != slctval.toString()) {
                try { getLoadPanelInstance().show(); } catch (e) { }
                $.ajax({
                    type: "GET",
                    url: turl,
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function () {
                        location.reload();
                    },
                    error: function (xhr) {
                        alert(xhr.statusText || "İstek başarısız");
                    },
                    complete: function () {
                        hideLoadPanelSafe();
                    }
                });
            }

        }

        function selectCompany_valueChanged(data) {
            var slctval = data.selectedItem.ID;

            var turl = konsolPageUrl + "?handler=GraphComp&ncompid=" + encodeURIComponent(slctval);
            if (misready == "ok" && mcompid.toString() != slctval.toString()) {
                try { getLoadPanelInstance().show(); } catch (e) { }
                $.ajax({
                    type: "GET",
                    url: turl,
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function () {
                        location.reload();
                    },
                    error: function (xhr) {
                        alert(xhr.statusText || "İstek başarısız");
                    },
                    complete: function () {
                        hideLoadPanelSafe();
                    }
                });
            }


        }


        var dt1 = "105";
    </script>
} 