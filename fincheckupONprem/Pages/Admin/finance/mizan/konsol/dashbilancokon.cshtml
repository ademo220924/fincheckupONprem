        public async Task<IActionResult> OnGetMarkupMarjin(DataSourceLoadOptions options, int myear, long compid)
        {
            /*
            List<DashBilancoViewMulti> chklist = new List<DashBilancoViewMulti>();
            if (compid < 1)
            {
                return new JsonResult(DataSourceLoader.Load(chklist, options));
            }



            nRequestList = DashGelirTablosu.Get_MAINBilancoMznAktMultiKon(compid);

            return new JsonResult(DataSourceLoader.Load(nRequestList.Where(x => x.IsHidden == 0), options));
       
       */
            
            try
            {
                var response = await _apiClient.GetMarkupMarjinAsync(new  MizanDashBilancoKonOnGetMarkupMarjinRequest()
                {
                    myear = myear,
                    compid = compid, options = options
                }, CancellationToken.None);
               
                if (response.IsSuccess && response.Data?.Response is JsonElement je)
                {
                    // API camelCase; PivotGrid DashBilancoViewMznShort alanlari PropertyNamingPolicy=null ile PascalCase bekler.
                    if (je.ValueKind == JsonValueKind.String)
                    {
                        var inner = je.GetString();
                        if (!string.IsNullOrEmpty(inner))
                        {
                            var normalizedInner = DevExtremeMarkupMarjinPayloadNormalizer.TryNormalizeDashBilancoViewMznShortPayload(inner);
                            return new ContentResult { Content = normalizedInner ?? inner, ContentType = "application/json" };
                        }
                    }
                    else if (je.ValueKind != JsonValueKind.Null && je.ValueKind != JsonValueKind.Undefined)
                    {
                        var normalized = DevExtremeMarkupMarjinPayloadNormalizer.TryNormalizeDashBilancoViewMznShortPayload(je.GetRawText());
                        return new ContentResult { Content = normalized ?? je.GetRawText(), ContentType = "application/json" };
                    }
                }

                Console.WriteLine(response.ProblemDetails?.Detail);
                var emptyRows = new List<DashBilancoViewMznShort>();
                return new JsonResult(DataSourceLoader.Load(emptyRows, options));
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                var emptyRows = new List<DashBilancoViewMznShort>();
                return new JsonResult(DataSourceLoader.Load(emptyRows, options));
            } 
            
        }
    }
}
