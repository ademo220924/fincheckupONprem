<input type="hidden" style="display:none" id="txtcurcomide" value="@Model.InitialModel.curcomID" />
<section class="content home">
    <div class="container-fluid">
        <div class="block-header">
            <div class="row clearfix">
                <div class="col-lg-5 col-md-5 col-sm-12">
                    <h2>Dashboard</h2>
                    <ul class="breadcrumb padding-0">
                        <li class="breadcrumb-item"><a href=""><i class="zmdi zmdi-home"></i></a></li>
                        <li class="breadcrumb-item active">Dashboard</li>
                    </ul>
                </div>
                <div class="col-lg-7 col-md-7 col-sm-12">
                    <div class="input-group m-b-0">
                        <div class="col-12">
                            <div class="card">
                                <div class="body">
                                    <div class="row">
                                        <div class="col-6" style="text-align:left">
                               

                                        </div>
                                        <div class="col-6" style="text-align:right">

                                         
                                            @(Html.DevExtreme().TextBox()
                                                .Value(Model.InitialModel.CompName).ReadOnly(true)
                            )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-6 col-md-6">
                <div class="card">
                    <div class="body l-seagreen text-center">

                        <h3 class="m-b-0 m-t-10 text-white"><span id="txterroredcombin" style="display:none">0</span></h3>
                        <span class="text-white">Smm Raporları</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 col-md-6">
                <div class="card">
                    <div class="body l-seagreen text-center">

                        <h3 class="m-b-0 m-t-10 text-white"> </h3>
                        <span class="text-white">SMM Yarı Mamul Oran (1-99): <input type="number" id="txtrowcount" min="1" max="99" style="color: white; background-color: #0c2c56 !important " value="@Model.InitialModel.Nacenum" class="form-control"></span>
                    </div>
                </div>
            </div>

        </div>
        <input type="hidden" style="display:none" id="txtmyear" value="@Model.InitialModel.CurrentUser.SelectedYear" />
        <input type="hidden" style="display:none" id="txtmcomp" value="@Model.InitialModel.CompID" />
        <input type="hidden" style="display:none" id="txtyearcount" value="@Model.InitialModel.YearCount" />
        <input type="hidden" style="display:none" id="txtcompcount" value="@Model.InitialModel.CompCount" />
        <input type="hidden" style="display:none" value="0" id="txtisupdate" />
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12">

                <script>
                    var tyear = $("#txtmyear").val();
                    var mcompid = $("#txtmcomp").val();
                    function onCellPrepared(e) {

                        if (e.columnIndex == 2 && e.rowType == "data") {
                            var chkk = e.data;
                            console.log(parseInt(chkk.TRowCount));
                            if (parseInt(chkk.TRowCount) < 1) {
                                e.cellElement.find(".dx-command-edit").remove();
                                e.cellElement.find(".dx-link-edit").remove();

                            }
                        }

                        if (e.columnIndex == 3 && e.rowType == "data") {
                            var chkk = e.data;

                            if (parseInt(chkk.TRowCount) < 1) {
                                e.cellElement.find(".dx-link-edit").remove();


                            }
                        }
                    }
                    var misready = "nok";
                    var chkReadyState = setInterval(function () {
                        if (document.readyState == "complete") {

                            clearInterval(chkReadyState);

                            misready = "ok";
                        }
                    }, 100);
                    function onRowPrepared(info) {
                        if (info.rowType != "header" && info.data.TxResult == "Bekleniyor") {

                            info.rowElement.addClass("orangecolor");
                        } else if (info.rowType != "header") {
                            info.rowElement.addClass("greencolor");
                        }
                    }
                    var dt1 = "0";
                    var compid = $("#txtmcomp").val();
                    var monthid = 0;
                    var year = $("#txtmyear").val();


 
                     
                    function funcUpload() {
                        $('#uploadInput').focus().trigger('click');
                        $("#griddiv").css("display", "none");
                    }








                    function startit() {
                        getLoadPanelInstance().show();

                    };
                   
                    function functionupdatetax(data) {
                        startit();
                        monthid = data;
                        var tnum = parseInt($("#txtrowcount").val());
                        if (tnum>99) {
                            $("#txtrowcount").val(99);
                        }
                        var fdatam = new FormData();
                        fdatam.append('companyid', $("#txtcurcomide").val());
                        fdatam.append('month', $("#txtrowcount").val() );
                        fdatam.append('year', data);

                        $.ajax({
                            url: "/JsonService/Mizan/moodUpdatesmm",
                            method: "POST",
                            statusCode: {
                                500: function () {
                                    getLoadPanelInstance().hide();
                                    Swal.fire({
                                        title: 'Server Erişim Sorunuz. Lütfen Sayfayı Yenileyiniz...',
                                        confirmButtonText: 'Yenile'
                                    }).then((result) => {
                                        /* Read more about isConfirmed, isDenied below */
                                        if (result.isConfirmed) {

                                            location.reload();
                                        }
                                    });
                                },
                                404: function () {
                                    alert("Script 404");
                                }
                            },
                            contentType: false,
                            data: fdatam,
                            processData: false,
                            cache: false,
                            success: function (data) {
                                getLoadPanelInstance().hide();
                                if (data == "nok") {

                                    Swal.fire(
                                        'Hata!',
                                        'Hata ile Karşılaşıldı!',
                                        'error'
                                    )
                                }
                                else {
                                    var arr = data.split('_');

                                    dt1 = arr[0];

                                    Swal.fire(
                                        'Başarılı!',
                                        'Güncelleme Tamamlandı!',
                                        'success'
                                    )
                                    setTimeout(function () {
                                        location.reload();
                                    }, 2000);


                                }


                            }
                        });


                    }

                </script>






                <div class="card">
                    <div class="body">

                        <div class="row">

                            <div class="col-md-12 col-lg-6">
                                <div class="col-md-12 col-lg-12">
                                    <div class="card" id="griddiv" style="display:none">
                                        <div class="header">


                                        </div>
                                        <div class="body">




                                        </div>

                                    </div>
                                </div>

                            </div>
                            <div class="col-md-12 col-lg-6">
                                <div class="row clearfix">
                                    <div class="col-md-12 col-lg-12">


                                        <div class="card">
                                            <div class="body">
                                                <div class="row">
                                                    @(Html.DevExtreme().DataGrid<YearlyErrorResult>
                                                                            ().ColumnHidingEnabled(true).ID("grdContYearDefter").OnCellPrepared("onCellPrepared").OnRowPrepared("onRowPrepared").ShowColumnLines(false).ShowBorders(false).ColumnAutoWidth(true)
                                                                            .Height(440) .Columns(columns =>
                                                                            {
                                                                            columns.AddFor(m => m.MainYear).Caption("Yıl").CssClass("centerdiv") ;
                                                                            columns.AddFor(m => m.MainMonth).Visible(false).SortOrder(SortOrder.Asc);

                                                                            columns.Add().CssClass("").Caption("Aksiyon").CellTemplate(@<text>
                                                                                <div onclick="functionupdatetax('[%= data.MainYear %]')" class="dxmain dx-link-edit dx-button dx-button-normal dx-button-mode-contained dx-widget dx-button-has-text" aria-label="Yükle" tabindex="0" role="button"><div class="dx-button-content"><span class="dx-button-text">Smm Çalıştır</span></div></div>


                                                                            </text>);

                                                                          


                                                                            columns.AddFor(m => m.TRowCount).Visible(false);

                                                                            }).DataSource(d => d.RemoteController().LoadUrl(Url.Page(null, "SalerDate"))
                                                                            ))
                                                </div>


                                            </div>
                                        </div>
                                    </div>

                                </div>



                            </div>

                        </div>



                    </div>

                </div>
            </div>

        </div>



    </div>
</section>
@(Html.DevExtreme().LoadPanel()
                    .ID("loadPanel")
                    .ShadingColor("rgba(0,0,0,0.4)")
                    .Position(p => p.Of("#employee"))
                    .Visible(false)
                    .ShowIndicator(true).Message("E-defter İşleniyor.. Lütfen Bekleyiniz...")
                    .ShowPane(true).Height(300).Width(500)
                    .Shading(true)
                    .HideOnOutsideClick(false)
                    .OnShown("loadPanel_shown")
                    )
<input type="text" id="mainyear" name="mainyear" value="@Model.InitialModel.CurrentUser.SelectedYear" style="display:none" />
<input type="text" id="mainmonth" name="mainmonth" style="display:none" />




@section Scripts{
    <script src="~/js/polyfill.min.js"></script>

    <script>
        function getLoadPanelInstance() {
            return $("#loadPanel").dxLoadPanel("instance");
        }
        function loadPanel_shown(e) {
            setTimeout(function () {
                e.component.hide();
            }, 610000);
        }
      

        var txcompname = $("txtcompname").val();

        function formatMessage(e) {

            return $("#txtcompname").val();
        }



    </script>

}

