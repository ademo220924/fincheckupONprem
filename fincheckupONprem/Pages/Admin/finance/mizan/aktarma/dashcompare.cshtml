        public async Task<JsonResult> OnGetMarkupMarjin(DataSourceLoadOptions options, long compid, int nmonth, int nyear)
        {
            try
            {
                var response = await _apiClient.GetMarkupMarjinAsync(new MizanAktarmaDashCompareOnGetMarkupMarjinRequest()
