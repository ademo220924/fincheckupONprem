@functions {
    public class IndexModel(IFinanceMizanReportMainTestMizanClient apiClient) : PageModel
    {
        private readonly IFinanceMizanReportMainTestMizanClient _apiClient = apiClient ?? throw new ArgumentNullException(nameof(apiClient));
        public MizanReportMainTestMizanRequestInitialModel InitialModel { get; set; } = new();

        public async Task OnGet()
        {
            try
            {
                var response = await _apiClient.GetAsync(new MizanReportMainTestMizanOnGetRequest(), CancellationToken.None);

                if (response.IsSuccess && response.Data?.InitialModel != null)
                {
                    InitialModel = response.Data.InitialModel;
                    InitialModel.CurrentUser ??= new HhvnUsers { SelectedYear = DateTime.Now.Year };
                    InitialModel.reportList ??= new List<CompanyReport>();
                    InitialModel.mreqListCompany ??= Array.Empty<Company>();
                    InitialModel.curCompany ??= new Company { NaceId = 0 };
                    InitialModel.CompName ??= string.Empty;
                    InitialModel.currentcompname ??= string.Empty;
                }
                else
                {
                    Console.WriteLine(response.ProblemDetails?.Detail ?? "ReportMainTestMizan OnGet: API başarısız.");
                    ApplyFallbackInitialModel();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                ApplyFallbackInitialModel();
            }
        }

        private void ApplyFallbackInitialModel()
        {
            InitialModel ??= new MizanReportMainTestMizanRequestInitialModel();
            InitialModel.CurrentUser = new HhvnUsers { SelectedYear = DateTime.Now.Year };
            InitialModel.reportList = new List<CompanyReport>();
            InitialModel.mreqListCompany = Array.Empty<Company>();
            InitialModel.curCompany = new Company { NaceId = 0 };
            InitialModel.CompName = string.Empty;
            InitialModel.currentcompname = string.Empty;
            InitialModel.curcomID = 0;
            InitialModel.curcomCount = 0;
            InitialModel.CompID = 0;
            InitialModel.CompCount = 0;
            InitialModel.YearCount = 0;
            InitialModel.YearCurrent = DateTime.Now.Year;
        }




        public async Task<JsonResult> OnGetSalerDate(DataSourceLoadOptions options)
        {
            try
            {
                await OnGet();
                
                var response = await _apiClient.GetSalerDateAsync(new MizanReportMainTestMizanOnGetSalerDateRequest
                    {
                        options = options
                    }, CancellationToken.None);

                if (response.IsSuccess)
                {
                    return new JsonResult(response.Data.Response);
                }

                Console.WriteLine(response.ProblemDetails.Detail);
                return new JsonResult("Burada hata var finance/mizan/ReportMainTestMizan OnGetSalerDate");
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
                throw;
            }
        }
        
