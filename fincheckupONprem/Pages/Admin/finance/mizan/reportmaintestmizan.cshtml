@section Scripts {
    <script src="~/js/polyfill.min.js"></script>

    <script>
        function funczone(data) {
            var turl = '/admin/finance/mizan/reportmaintestmizan?handler=CheckUrl&fileID=' + data;

 
            $.ajax({
                type: "GET",
                url: turl,
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {


      
                    console.log(response);

                    if (response == "nok") {
                        Swal.fire(
                            'Uyarı!',
                            'Hata Kaydı Bulunamadı!',
                            'error'
                        )
                        return;
                    }
                    else {
                        var url;
                        var word;
                        if (typeof response === 'string' && (response.indexOf('http://') === 0 || response.indexOf('https://') === 0)) {
                            url = response;
                            word = response.substring(response.lastIndexOf('/') + 1);
                        } else {
                            var chkdomain = $(location).attr('host');
                            var proto = window.location.protocol + '//';
                            const myArray = response.split("/");
                            word = myArray[myArray.length - 1];
                            url = proto + chkdomain + '/' + response;
                        }
                        console.log(url);
