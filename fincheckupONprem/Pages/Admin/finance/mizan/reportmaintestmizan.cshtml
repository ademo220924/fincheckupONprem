        public async Task<JsonResult> OnGetCheckUrl(long fileID)
        {
            try
            {
                await OnGet();

                var response = await _apiClient.GetCheckUrlAsync(new MizanReportMainTestMizanOnGetCheckUrlRequest
                    {
                        fileID = fileID
                    }, CancellationToken.None);

                MizanReportMainTestMizanOnGetCheckUrlResponse? checkUrlPayload = response.Data;
                var fileUrl = checkUrlPayload?.FileUrl;
                if (response.IsSuccess && !string.IsNullOrEmpty(fileUrl))
                {
                    return new JsonResult(fileUrl);
                }

                Console.WriteLine(response.ProblemDetails?.Detail);
                return new JsonResult("Burada hata var finance/mizan/ReportMainTestMizan OnGetCheckUrl");
