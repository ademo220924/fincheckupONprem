        public async Task<JsonResult> OnGetCheckRepPdf(long companyID, string nacceco)
        {
            try
            {
                await OnGet();

                var response = await _apiClient.GetCheckRepPdfAsync(new MizanReportMainTestMizanOnGetCheckRepPdfQuery()
                    { InitialModel = InitialModel, Request = new MizanReportMainTestMizanOnGetCheckRepPdfRequest()
                        {
                        companyID = companyID,
                        nacceco = nacceco
