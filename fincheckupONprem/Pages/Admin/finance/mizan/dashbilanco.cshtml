        public async Task<IActionResult> OnGetMarkupMarjin(DataSourceLoadOptions options, string myear, long compid)
        {
            try
            {
                await OnGet();
                if (string.IsNullOrWhiteSpace(myear) && InitialModel?.CurrentUser != null)
                {
                    myear = InitialModel.CurrentUser.SelectedYear.ToString();
                }

                var response = await _apiClient.GetMarkupMarjinAsync(new MizanDashBilancoOnGetMarkupMarjinRequest
                    {
                        options = options,
                        myear = myear,
                        compid = compid
                    }, CancellationToken.None);

                if (response.IsSuccess && response.Data?.Response is JsonElement je)
                {
                    // JsonResult(JsonElement) bazen çift serileştirme yapar; DevExtreme kökte { "data": [...] } bekler.
                    if (je.ValueKind == JsonValueKind.String)
                    {
                        var inner = je.GetString();
                        if (!string.IsNullOrEmpty(inner))
                        {
                            return new ContentResult { Content = inner, ContentType = "application/json" };
                        }
                    }
                    else if (je.ValueKind != JsonValueKind.Null && je.ValueKind != JsonValueKind.Undefined)
                    {
                        return new ContentResult { Content = je.GetRawText(), ContentType = "application/json" };
                    }
                }

                Console.WriteLine(response.ProblemDetails?.Detail);
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex.Message);
            }

            return new JsonResult(DataSourceLoader.Load(Array.Empty<DashBilancoViewMulti>(), options));

            //List<DashBilancoViewMulti> chklist = new List<DashBilancoViewMulti>();
            //
            //
            //var chk = DashGelirTablosu.Get_MAINRESULTMultiMain(compid).Where(x => x.IsHidden == 0);
            //return new JsonResult(DataSourceLoader.Load(chk, options));
        }
