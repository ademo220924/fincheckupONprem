@section Scripts {
    <script src="~/js/polyfill.min.js"></script>

    <script>
        var changedBySelectBox;
        var titleSelectBox;
        var clearSelectionButton;
        function button_onInitialized(e) {
            clearSelectionButton = e.component;
        }
        function onInitializedgrid(e) {
            // e.component.selectAll();
        }

        function button_click() {
            getDataGridInstance().clearSelection();
        }
        function getDataGridInstance() {
            return $("#grdContYearDefterz").dxDataGrid("instance");
        }

        function selection_changed(selectedItems) {

            var dataGrid = getDataGridInstance();
            var data = selectedItems.selectedRowsData;
            clearSelectionButton.option('enabled', true);
            if (data.length > 0) {
                $("#selectedItemsContainer").val(
                    data
                        .map((value) => `${value.TypeID}`)
                        .join(",")
                );
            } else {
                $("#selectedItemsContainer").val("");
            }
            /*   setfdate($("#selectedItemsContainer").val());*/
            clearSelectionButton.option('disabled', !data.length);
        }
        function getLoadPanelInstance() {
            return $("#loadPanel").dxLoadPanel("instance");
        }
        function loadPanel_shown(e) {
            setTimeout(function () {
                e.component.hide();
            }, 610000);
        }
        function functionupdate(data) {


            var turl = '/admin/finance/mizan/uppageaktarma?handler=CheckRepPdf&nyear=' + data + '&companyID=@Model.InitialModel.curcomID';


            getLoadPanelInstance().show();
            $.ajax({
                type: "GET",
                url: turl,
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {


                    getLoadPanelInstance().hide();
                    console.log(response);

                    if (response == "nok") {
                        Swal.fire(
                            'Uyarı!',
                            'Hata Kaydı Bulunamadı!',
                            'error'
                        )
                        return;
                    }
                    else {


                        var chkdomain = $(location).attr('host');


                        const myArray = response.split("/");
                        let word = myArray[1];
                        var url = 'https://' + chkdomain + '/' + response;
                        // window.location.href = 'https://' + chkdomain + response;
                        console.log(url);
                        var link = document.createElement('a');
                        link.href = url;
                        link.download = word;
                        link.dispatchEvent(new MouseEvent('click'));
                    }

                },
                failure: function (response) {
                    alert(response);
                }
            });
        }
        function functionupdateBlnc(data) {

            var monthide = data;
            $("#mainmonth").val(monthide);
            var compidz = $("#txtmcomp").val();

            var yearz = $("#txtmyear").val();
            window.open(
                '/admin/finance/mizan/dashbilancoakt?myear=' + data,
                '_blank' // <- This is what makes it open in a new window.
            );
        }
        function functionupdateRvn(data) {

            var monthide = data;
            $("#mainmonth").val(monthide);
            var compidz = $("#txtmcomp").val();

            var yearz = $("#txtmyear").val();
            window.open(
                '/admin/finance/mizan/dashbilancorvnakt?myear=' + data,
                '_blank' // <- This is what makes it open in a new window.
            );
        }

        var txcompname = $("txtcompname").val();

        function formatMessage(e) {

            return $("#txtcompname").val();
        }



    </script>

}

