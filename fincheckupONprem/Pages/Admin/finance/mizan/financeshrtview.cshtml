                                        <div class="col-4 left-side">
                                            <span class="tttt" style="text-align:left">@item.MainYear</span> 
                                        </div>
                                        <div class="col-8 right-side" style="text-align:right">
                                            <span class="tttt" style="text-align:right">@item.Amount.ToString("n0") </span>
                                        </div>
                                            
                                        } 
                                    <div class="col-12" style="min-height:5px !important;">
                                   

                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
